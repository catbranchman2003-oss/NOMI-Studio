"use client";

import { useState } from "react";
import { motion } from "framer-motion";
import { useForm } from "./FormContext";
import FormField from "./FormField";

export default function Step4Contact() {
  const { formData, updateForm, setStep } = useForm();
  const [fields, setFields] = useState({
    email: formData.email || "",
    telegram: formData.telegram || "",
    instagram: formData.instagram || "",
    discord: formData.discord || "",
  });
  const [error, setError] = useState("");

  const update = (key: string, value: string) =>
    setFields((prev) => ({ ...prev, [key]: value }));

  const handleContinue = () => {
    if (!fields.email || !fields.instagram) {
      setError("Email and Instagram are required.");
      return;
    }
    const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    if (!emailRegex.test(fields.email)) {
      setError("Please enter a valid email address.");
      return;
    }
    updateForm(fields);
    setStep(5);
  };

  return (
    <motion.div
      initial={{ opacity: 0, y: 16 }}
      animate={{ opacity: 1, y: 0 }}
      exit={{ opacity: 0, y: -16 }}
      transition={{ duration: 0.5, ease: [0.22, 1, 0.36, 1] }}
      className="space-y-10"
    >
      <div>
        <h2 className="font-serif text-petal text-2xl md:text-3xl mb-3">
          How to reach you.
        </h2>
        <p className="text-mint/50 font-sans font-light text-sm leading-relaxed">
          We review applications manually. If there is alignment, we will be
          in touch through your preferred contact.
        </p>
      </div>

      <div className="space-y-8">
        <FormField
          label="Email address"
          type="email"
          placeholder="your@email.com"
          value={fields.email}
          onChange={(e) => update("email", e.target.value)}
          required
        />
        <FormField
          label="Instagram"
          placeholder="@yourhandle"
          value={fields.instagram}
          onChange={(e) => update("instagram", e.target.value)}
          required
        />
        <FormField
          label="Telegram"
          placeholder="@yourhandle"
          value={fields.telegram}
          onChange={(e) => update("telegram", e.target.value)}
          optional
        />
        <FormField
          label="Discord"
          placeholder="username#0000"
          value={fields.discord}
          onChange={(e) => update("discord", e.target.value)}
          optional
        />
      </div>

      {error && <p className="text-rose/70 text-xs font-sans">{error}</p>}

      <div className="flex gap-6">
        <button
          onClick={() => setStep(3)}
          className="text-mint/30 text-xs tracking-[0.1em] uppercase font-sans hover:text-mint/60 transition-colors duration-300"
        >
          ← Back
        </button>
        <button
          onClick={handleContinue}
          className="border border-blush/30 text-petal px-10 py-3.5 text-xs tracking-[0.15em] uppercase font-sans font-medium hover:bg-blush/8 hover:border-blush/60 transition-all duration-500"
        >
          Review Application
        </button>
      </div>
    </motion.div>
  );
}
