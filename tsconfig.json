"use client";

import { useState } from "react";
import { motion } from "framer-motion";
import { useForm } from "./FormContext";
import FormField from "./FormField";

export default function Step2CreatorInfo() {
  const { formData, updateForm, setStep } = useForm();
  const [fields, setFields] = useState({
    creator_name: formData.creator_name || "",
    platform_links: formData.platform_links || "",
    audience_size: formData.audience_size || "",
    subscription_price: formData.subscription_price || "",
    biggest_challenge: formData.biggest_challenge || "",
    want_help_with: formData.want_help_with || "",
  });
  const [error, setError] = useState("");

  const update = (key: string, value: string) =>
    setFields((prev) => ({ ...prev, [key]: value }));

  const handleContinue = () => {
    if (!fields.creator_name || !fields.platform_links || !fields.biggest_challenge || !fields.want_help_with) {
      setError("Please fill in all required fields.");
      return;
    }
    updateForm(fields);
    setStep(3);
  };

  return (
    <motion.div
      initial={{ opacity: 0, y: 16 }}
      animate={{ opacity: 1, y: 0 }}
      exit={{ opacity: 0, y: -16 }}
      transition={{ duration: 0.5, ease: [0.22, 1, 0.36, 1] }}
      className="space-y-10"
    >
      <div>
        <h2 className="font-serif text-petal text-2xl md:text-3xl mb-3">
          Tell us about your work.
        </h2>
        <p className="text-mint/50 font-sans font-light text-sm leading-relaxed">
          A few details to help us understand where you are right now.
        </p>
      </div>

      <div className="space-y-8">
        <FormField
          label="Creator name"
          placeholder="How you're known to your audience"
          value={fields.creator_name}
          onChange={(e) => update("creator_name", e.target.value)}
          required
        />
        <FormField
          label="Platform links"
          placeholder="Link to your primary platform profile"
          value={fields.platform_links}
          onChange={(e) => update("platform_links", e.target.value)}
          required
        />
        <div className="grid grid-cols-2 gap-6">
          <FormField
            label="Current audience size"
            placeholder="Approx. subscriber count"
            value={fields.audience_size}
            onChange={(e) => update("audience_size", e.target.value)}
          />
          <FormField
            label="Subscription price"
            placeholder="e.g. $9.99/month"
            value={fields.subscription_price}
            onChange={(e) => update("subscription_price", e.target.value)}
          />
        </div>
        <FormField
          as="textarea"
          label="Biggest current challenge"
          placeholder="What's the main thing holding you back right now?"
          value={fields.biggest_challenge}
          onChange={(e) => update("biggest_challenge", e.target.value)}
          required
        />
        <FormField
          as="textarea"
          label="What you want help improving"
          placeholder="Retention, monetisation, positioning — be specific"
          value={fields.want_help_with}
          onChange={(e) => update("want_help_with", e.target.value)}
          required
        />
      </div>

      {error && <p className="text-rose/70 text-xs font-sans">{error}</p>}

      <div className="flex gap-6">
        <button
          onClick={() => setStep(1)}
          className="text-mint/30 text-xs tracking-[0.1em] uppercase font-sans hover:text-mint/60 transition-colors duration-300"
        >
          ← Back
        </button>
        <button
          onClick={handleContinue}
          className="border border-blush/30 text-petal px-10 py-3.5 text-xs tracking-[0.15em] uppercase font-sans font-medium hover:bg-blush/8 hover:border-blush/60 transition-all duration-500"
        >
          Continue
        </button>
      </div>
    </motion.div>
  );
}
